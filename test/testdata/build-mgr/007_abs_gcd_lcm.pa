cinclude <stdio.h>;

func abs(int64 x) -> int64 {
    if x < 0 { return -x; }
    return x;
}

func gcd(int64 a, int64 b) -> int64 {
    if b == 0 { return a; }
    return gcd(b, a % b);
}

func lcm(int64 a, int64 b) -> int64 {
    return a / gcd(a, b) * b;
}

printf("abs=%ld gcd=%ld lcm=%ld abs=%ld gcd=%ld lcm=%ld\n",
    abs(-42), gcd(12, 8), lcm(4, 6),
    abs(-7),  gcd(48, 18), lcm(6, 10));
