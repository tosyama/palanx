cinclude <stdio.h>;

int64 rows = 2;
int64 cols = 3;
[rows][cols]int32 mat;

int32(1) -> mat[0][0]; int32(2) -> mat[0][1]; int32(3) -> mat[0][2];
int32(4) -> mat[1][0]; int32(5) -> mat[1][1]; int32(6) -> mat[1][2];

printf("%d %d %d\n", mat[0][0], mat[0][1], mat[0][2]);
printf("%d %d %d\n", mat[1][0], mat[1][1], mat[1][2]);
