cinclude <stdio.h>;

// Case 1: interleaved int and float args (all in registers)
int64 a = 10;
int64 b = 20;
flo64 x = 3.5;
printf("%ld %f %ld\n", a, x, b);

// Case 2: int args overflow to stack, float still in xmm
int64 i1=1, i2=2, i3=3, i4=4, i5=5, i6=6, i7=7;
flo64 y = 0.5;
printf("%ld %ld %ld %ld %ld %ld %ld %f\n", i1, i2, i3, i4, i5, i6, i7, y);

// Case 3: float args overflow to stack (9 floats, xmm0-xmm7 + stack)
flo64 f1=1.0, f2=2.0, f3=3.0, f4=4.0, f5=5.0, f6=6.0, f7=7.0, f8=8.0, f9=9.0;
printf("%f %f %f %f %f %f %f %f %f\n", f1, f2, f3, f4, f5, f6, f7, f8, f9);
