cinclude <stdio.h>;

func collatz_steps(int64 n) -> int64 {
    int64 steps = 0;
    while n != 1 {
        if n % 2 == 0 { n / 2 -> n; }
        else { n * 3 + 1 -> n; }
        steps + 1 -> steps;
    }
    return steps;
}

printf("collatz(27) = %ld\n", collatz_steps(27));
printf("collatz(871) = %ld\n", collatz_steps(871));
