cinclude <stdio.h>;

func fizzbuzz(int64 n) {
    int64 i = 1;
    while i <= n {
        if i % 15 == 0 { printf("FizzBuzz\n"); }
        else if i % 3 == 0 { printf("Fizz\n"); }
        else if i % 5 == 0 { printf("Buzz\n"); }
        else { printf("%ld\n", i); }
        i + 1 -> i;
    }
}

fizzbuzz(20);
