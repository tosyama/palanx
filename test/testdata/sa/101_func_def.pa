func add(int32 a, int32 b) -> int32 {
    return a + b;
}

func identity(int64 x) -> int64 {
    return x;
}

func divmod(int64 a, int64 b) -> int64 q, int64 r {
    a -> q;
    return;
}

func widen(int32 x) -> int64 {
    return x;
}

func sumsOf(int64 a, int64 b) -> int64 s, int64 d {
    a + b -> s;
    a - b -> d;
    return;
}

(int64 s, int64 d) = sumsOf(10, 3);

func recurse(int64 n) -> int64 {
    return recurse(n);
}
